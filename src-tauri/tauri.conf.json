{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "vigilance",
  "version": "0.1.1",
  "identifier": "com.danrobotics.vigilance",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Vigilance — Network Monitor",
        "width": 1400,
        "height": 800,
        "resizable": true,
        "devtools": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
    "resources/GeoLite2-Country.mmdb": "GeoLite2-Country.mmdb",
    "resources/config.example.json": "config.example.json",
    "resources/config.json": "config.json"
},
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}